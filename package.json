{
  "name": "@stableops/wallet-ui",
  "version": "0.3.6",
  "private": false,
  "description": "Shared React wallet UI components for StableOps checkout and playground experiences.",
  "keywords": [
    "stableops",
    "wallet",
    "walletconnect",
    "react",
    "ui"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/StableOps/stableops-wallet-ui.git"
  },
  "homepage": "https://stableops.dev",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./walletconnect-dialog.css": "./dist/walletconnect-dialog.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "pnpm build",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@stableops/wallet-sdk": "workspace:^",
    "lucide-react": "^0.469.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.16.0",
    "globals": "^15.14.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.18.0",
    "vitest": "^3.2.4"
  }
}
